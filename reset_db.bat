@echo off
chcp 65001 >nul
title Badge Collector - Сброс базы данных
color 0C

echo ================================================
echo        СБРОС БАЗЫ ДАННЫХ
echo ================================================
echo.
echo ВНИМАНИЕ! Это действие удалит ВСЕ данные:
echo   - пользователей
echo   - категории
echo   - наборы
echo   - значки
echo   - фотографии
echo   - теги
echo.
echo Данные будут удалены БЕЗВОЗВРАТНО!
echo.
set /p confirm="Вы уверены? (Введите ДА для подтверждения): "

if not "%confirm%"=="ДА" (
    echo.
    echo Операция отменена.
    pause
    exit /b
)

echo.
echo ================================================
echo   Удаление базы данных...
echo ================================================

cd backend

if exist "badge_collector.db" (
    del /f /q "badge_collector.db"
    echo ✓ Файл базы данных удален
) else (
    echo База данных не найдена
)

echo.
echo ================================================
echo   Удаление загруженных фото...
echo ================================================

if exist "uploads" (
    rmdir /s /q "uploads"
    echo ✓ Папка uploads удалена
)

mkdir "uploads"
echo ✓ Создана новая папка uploads

echo.
echo ================================================
echo   Создание новой базы данных...
echo ================================================

python database\init_db.py

if %errorlevel% neq 0 (
    echo.
    echo ❌ Ошибка при создании базы данных!
    pause
    exit /b
)

echo.
echo ================================================
echo   ✅ БАЗА ДАННЫХ УСПЕШНО ПЕРЕСОЗДАНА!
echo ================================================
echo.
echo Теперь вы можете:
echo   1. Запустить сервер: run.bat
echo   2. Зарегистрировать нового пользователя
echo   3. Назначить админа: admin.bat
echo.

pause